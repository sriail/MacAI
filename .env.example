# Required: Cerebras API key (https://cloud.cerebras.ai)
CEREBRAS_API_KEY=your_cerebras_api_key_here

# Optional: SearXNG URL override.
# - When running via `docker compose up` this is set automatically to http://searxng:8080
# - When running with `npm start` (no Docker) the default is http://localhost:8888
# - Override here if your SearXNG instance is hosted elsewhere
# SEARXNG_URL=http://localhost:8888

# Optional: Port for the Node.js server (default: 3000)
# PORT=3000
